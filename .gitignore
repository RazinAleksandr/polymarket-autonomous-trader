# Claude Code CLI user-level config (defensive: prevents committing global ~/.claude contents if mixed in)
# Only commit our own .claude/CLAUDE.md and skills — never cache, sessions, credentials
.claude/backups/
.claude/cache/
.claude/sessions/
.claude/session-env/
.claude/file-history/
.claude/projects/
.claude/plugins/
.claude/history.jsonl
.claude/.credentials.json
.claude/mcp-needs-auth-cache.json
.claude/policy-limits.json
.claude/settings.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo

# Python (if outer ever runs python)
__pycache__/
*.pyc
.venv/

# Worktrees directory (if user keeps worktrees at repo root)
.worktrees/
